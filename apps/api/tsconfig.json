{
	"compilerOptions": {
		"target": "ES2020",
// 		"module": "CommonJS",
		"module": "NodeNext",
    	"moduleResolution": "NodeNext",
    	"allowJs": true,
		"allowImportingTsExtensions": true,
    	"noEmit": true,
		"rootDir": "src",
		"outDir": "dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": ["src"]
}
